{
  "manifest_version": 3,
  "name": "TextForge - Local AI Writing Assistant",
  "version": "1.1.0",
  "description": "Rewrite, summarize & polish text using your local AI. Works with Ollama, LM Studio, and any OpenAI-compatible server. 100% private.",
  "permissions": ["storage"],
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "TextForge Settings"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
